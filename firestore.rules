rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is a parent of this family.
    // Either their uid IS the familyId (creator) or parentMembers maps them.
    function isParent(familyId) {
      return request.auth != null && (
        request.auth.uid == familyId ||
        exists(/databases/$(database)/documents/parentMembers/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/parentMembers/$(request.auth.uid)).data.familyId == familyId
      );
    }

    // Helper: any authenticated user (parents + anonymous kids).
    function isAuthenticated() {
      return request.auth != null;
    }



    match /families/{familyId} {
      // Parents can read and write family config.
      // Kids (anonymous) can read so they see children, tasks, rewards, settings.
      allow read: if isAuthenticated();
      allow write: if isParent(familyId);

      match /children/{childId} {
        allow read: if isAuthenticated();
        allow create, delete: if isParent(familyId);
        // Parents can update anything; kids can only update the pin field
        allow update: if isParent(familyId) ||
          (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pin']));
      }

      match /tasks/{taskId} {
        allow read: if isAuthenticated();
        allow write: if isParent(familyId);
      }

      match /rewards/{rewardId} {
        allow read: if isAuthenticated();
        allow write: if isParent(familyId);
      }

      match /childData/{childId} {
        // Both parents and kids need read + write on child data
        // (kids write task completions, redemption requests, etc.)
        allow read, write: if isAuthenticated();

        match /{subcol}/{docId} {
          allow read, write: if isAuthenticated();
        }
      }

      match /coopRequests/{requestId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() &&
          request.resource.data.keys().hasOnly([
            'taskId', 'initiatorId', 'partnerId', 'status', 'date',
            'createdAt', 'partnerRespondedAt', 'parentResolvedAt', 'completedAt',
            'windowStartOverride', 'windowEndOverride', 'coinOverride',
            'initiatorCompleted', 'partnerCompleted',
            'taskName', 'taskTier', 'initiatorName', 'partnerName'
          ]) &&
          request.resource.data.status == 'pending_partner' &&
          request.resource.data.initiatorCompleted == false &&
          request.resource.data.partnerCompleted == false;
        // Parents can approve/deny and set override fields.
        allow update: if isParent(familyId) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'parentResolvedAt', 'coinOverride',
                      'windowStartOverride', 'windowEndOverride']) &&
          request.resource.data.status in ['approved', 'denied'];
        // Any authenticated user can drive partner response, cancellation, and completion.
        // The resulting status must not be a parent-only terminal state.
        allow update: if isAuthenticated() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'partnerRespondedAt', 'completedAt',
                      'initiatorCompleted', 'partnerCompleted']) &&
          !(request.resource.data.status in ['approved', 'denied']);
        allow delete: if isParent(familyId);
      }

      match /notifications/{notifId} {
        // Both parents and kids need read/create (kids trigger notifications
        // for parents via task completions and loot requests).
        // Anonymous kids can't be tied to a specific family in rules.
        allow read: if isAuthenticated();
        // Validate schema and restrict to known types
        allow create: if isAuthenticated() &&
          request.resource.data.keys().hasAll(['type', 'title', 'body', 'targetRole', 'read', 'createdAt']) &&
          request.resource.data.type in [
            'mission_complete', 'mission_rejected', 'loot_request',
            'loot_approved', 'loot_denied', 'level_up', 'streak',
            'coop_request', 'coop_accepted', 'coop_declined', 'coop_approved',
            'coop_denied', 'coop_cancelled', 'coop_partner_done', 'coop_complete', 'coop_expired'
          ] &&
          request.resource.data.targetRole in ['parent', 'kid'] &&
          request.resource.data.read == false &&
          request.resource.data.title is string &&
          request.resource.data.body is string;
        // Only allow updating the 'read' field
        allow update: if isAuthenticated() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        // Parents can delete notifications
        allow delete: if isParent(familyId);
      }
    }

    // Feedback — any authenticated user can submit
    match /feedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }

    // Family codes — public read for kid enrollment, parents can create and delete
    match /familyCodes/{code} {
      allow read: if true;
      allow create: if isParent(request.resource.data.familyId);
      allow delete: if isParent(resource.data.familyId);
      allow update: if false;
    }

    // Parent member mapping — users can read/write their own doc.
    // The family owner (uid == familyId) can also read and delete
    // other members' docs during family deletion.
    match /parentMembers/{uid} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        resource.data.familyId == request.auth.uid
      );
      // TODO: Move family joins to a Cloud Function for proper joinCode validation.
      // The exists() check is a stopgap — it prevents arbitrary familyId values
      // but doesn't verify the user has a valid join code.
      allow create: if request.auth != null && request.auth.uid == uid &&
        (
          request.resource.data.familyId == uid ||
          exists(/databases/$(database)/documents/families/$(request.resource.data.familyId))
        );
      allow update: if request.auth != null && request.auth.uid == uid &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['familyId']);
      allow delete: if request.auth != null && (
        request.auth.uid == uid ||
        resource.data.familyId == request.auth.uid
      );
    }
  }
}
