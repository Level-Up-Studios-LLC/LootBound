rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /families/{familyId}/{allPaths=**} {
      // Allow any authenticated user to read/write family photos.
      // Family-level isolation is enforced at the application layer
      // (familyId is resolved from parentMembers mapping).
      // A tighter rule would use custom claims with familyId,
      // but that requires a Cloud Function to set claims on sign-up.
      allow read, write: if request.auth != null;
    }
  }
}
